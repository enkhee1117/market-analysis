# Copy this file to secrets.toml and fill in your API key.
# Do NOT commit secrets.toml to git (it's in .gitignore).

MASSIVE_API_KEY = "your_massive_api_key_here"

# Supabase (persistent cache — optional, app works without it)
SUPABASE_URL = "https://yourproject.supabase.co"
SUPABASE_KEY = "your_anon_key_here"
